# Copy this file to ".env" and fill in your real values (never commit .env to git)

# Any random string you make up yourself — you'll enter this same string
# in the Facebook Developer Console when you set up the webhook.
VERIFY_TOKEN=choose_any_secret_string_here

# Generated from your Facebook Page in the Developer Console
# (Messenger > Settings > Access Tokens)
PAGE_ACCESS_TOKEN=paste_your_page_access_token_here

# Port your server listens on (most hosts set this automatically)
PORT=3000
